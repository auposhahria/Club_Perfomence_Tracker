<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#B0D8D8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Rank Badge -->
        <FrameLayout
            android:id="@+id/flRankBadge"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_rank_badge">

            <TextView
                android:id="@+id/tvRank"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#0F6E56" />

            <ImageView
                android:id="@+id/ivCrown"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_crown"
                android:visibility="gone"
                app:tint="#E1F5EE" />

        </FrameLayout>

        <!-- User Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="shahria_cf"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#04342C" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvUserRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expert"
                    android:textSize="12sp"
                    android:textColor="#5DCAA5" />

                <TextView
                    android:id="@+id/tvGlobalRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | Global: #1234"
                    android:textSize="11sp"
                    android:textColor="#757575"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSolved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solved: 5"
                android:textSize="11sp"
                android:textColor="#455A64"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Rating / Score -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1847"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0F6E56"
            android:layout_marginStart="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>