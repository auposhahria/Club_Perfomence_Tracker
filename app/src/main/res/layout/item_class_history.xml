<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#B0D8D8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Icon Box -->
        <LinearLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:background="@drawable/bg_icon_box_teal"
            android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                android:tint="#0F6E56" />

        </LinearLayout>

        <!-- Class Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvClassName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#04342C"
                android:text="Class Name" />

            <TextView
                android:id="@+id/tvClassDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#5DCAA5"
                android:layout_marginTop="2dp"
                android:text="Mon, 24 Jun 2024 · 10:00 AM" />

        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvAttendanceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_badge_teal"
            android:textColor="#0F6E56"
            android:text="Present" />

    </LinearLayout>

</androidx.cardview.widget.CardView>