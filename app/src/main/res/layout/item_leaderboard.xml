<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="#B0D8D8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Rank Badge / Avatar -->
        <TextView
            android:id="@+id/tvRankBadge"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#0F6E56"
            android:background="@drawable/bg_rank_badge"
            android:text="1"
            android:layout_marginEnd="10dp" />

        <!-- User Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCfHandle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#04342C"
                android:text="cf_username" />

            <TextView
                android:id="@+id/tvCfRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#5DCAA5"
                android:layout_marginTop="2dp"
                android:text="Specialist" />

        </LinearLayout>

        <!-- Rating -->
        <TextView
            android:id="@+id/tvCfRating"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0F6E56"
            android:gravity="end"
            android:text="1847" />

    </LinearLayout>

</androidx.cardview.widget.CardView>