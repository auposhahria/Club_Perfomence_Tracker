<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Responsive Header Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/ivProfileAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_avatar_circle"
                android:src="@drawable/ic_profile"
                app:tint="@color/white"
                android:padding="8dp"
                android:contentDescription="Profile" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/ivProfileAvatar"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:text="Welcome!"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:ellipsize="end"
                android:maxLines="2" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Solving Progress Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/primary"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ladder Progress"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvProgressStats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/50 Problems Solved"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressLadder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="0"
                        app:indicatorSize="56dp"
                        app:trackThickness="6dp"
                        app:indicatorColor="@color/primary"
                        app:trackColor="#E1F5EE" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2x2 Responsive Grid using ConstraintLayout -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Top Left: Total Classes -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalClasses"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E5E7EB"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/cardAttendedClasses">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Classes" android:textAppearance="?attr/textAppearanceLabelLarge" android:textColor="@color/text_secondary"/>
                        <TextView android:id="@+id/tvTotalClasses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textAppearance="?attr/textAppearanceHeadlineSmall" android:textColor="@color/text_primary" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Top Right: Attended -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAttendedClasses"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E5E7EB"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardTotalClasses">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Attended" android:textAppearance="?attr/textAppearanceLabelLarge" android:textColor="@color/text_secondary"/>
                        <TextView android:id="@+id/tvAttendedClasses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textAppearance="?attr/textAppearanceHeadlineSmall" android:textColor="@color/text_primary" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Bottom Left: CF Rating -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCfRating"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@android:color/transparent"
                    app:layout_constraintTop_toBottomOf="@id/cardTotalClasses"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/cardClubRating">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CF Rating" android:textAppearance="?attr/textAppearanceLabelLarge" android:textColor="@color/text_secondary"/>
                        <TextView android:id="@+id/tvCfRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textAppearance="?attr/textAppearanceHeadlineSmall" android:textColor="@color/text_primary" android:textStyle="bold" />
                        <TextView android:id="@+id/tvCfRank" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Unrated" android:textAppearance="?attr/textAppearanceLabelSmall" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Bottom Right: Club Rating -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardClubRating"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E5E7EB"
                    app:layout_constraintTop_toBottomOf="@id/cardAttendedClasses"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardCfRating">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Club Rating" android:textAppearance="?attr/textAppearanceLabelLarge" android:textColor="@color/text_secondary"/>
                        <TextView android:id="@+id/tvClubRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textAppearance="?attr/textAppearanceHeadlineSmall" android:textColor="@color/text_primary" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Achievements"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/primary"
                app:cardBackgroundColor="@color/attendance_present_bg">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="• Solved 5 new problems this week\n• Attended 'Graph Theory' class\n• Reached 'Expert' on Codeforces!"
                    android:textColor="@color/attendance_present_text"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>