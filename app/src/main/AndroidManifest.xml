<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo_cpckiu"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_cpckiu"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClubPerfomenceTracker"
        android:largeHeap="true">

        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity android:name=".TeamSelectionActivity" />
        <activity android:name=".CodeforcesContestActivity" />
        <activity android:name=".ProgrammerDetailActivity" />
        <activity android:name=".LoginActivity" />
        <activity android:name=".SignUpActivity" />
        <activity android:name=".CreatePostActivity" />
        <activity android:name=".BlogDetailActivity" />
        <activity android:name=".ProfileActivity" />
        <activity android:name=".ClassHistoryActivity" />
        <activity android:name=".AdminMainActivity" />
        <activity android:name=".AddClassActivity" />

    </application>

</manifest>